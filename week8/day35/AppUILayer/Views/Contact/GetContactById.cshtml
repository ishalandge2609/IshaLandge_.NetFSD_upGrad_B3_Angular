@model DataAccessLayer.Models.ContactInfo

<div class="container mt-4">
    <h2>Contact Details</h2>
    <hr />

    <div class="card p-3">
        <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
        <p><strong>Email:</strong> @Model.EmailId</p>
        <p><strong>Mobile:</strong> @Model.MobileNo</p>
        <p><strong>Designation:</strong> @Model.Designation</p>
        <p><strong>Company:</strong> @Model.CompanyId</p>
        <p><strong>Department:</strong> @Model.DepartmentId</p>
    </div>

    <a asp-controller="Contact" asp-action="ShowContacts" class="btn btn-secondary">
        Back
    </a>
</div>