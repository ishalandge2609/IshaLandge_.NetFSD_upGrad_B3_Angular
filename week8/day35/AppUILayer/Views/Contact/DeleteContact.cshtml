@model DataAccessLayer.Models.ContactInfo

<div class="container mt-4">
    <h2>Delete Contact</h2>

    <div class="alert alert-danger">
        Are you sure you want to delete this contact?
    </div>

    <div class="card p-3">
        <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
        <p><strong>Email:</strong> @Model.EmailId</p>
    </div>

    <form asp-controller="Contact" asp-action="DeleteConfirmed" asp-route-id="@Model.ContactId" method="post">

        <button type="submit" class="btn btn-danger">Delete</button>

        <a asp-controller="Contact" asp-action="ShowContacts" class="btn btn-secondary">
            Cancel
        </a>
    </form>
</div>
}
