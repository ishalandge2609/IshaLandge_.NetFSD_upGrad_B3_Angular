@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model List<MyFirstMVCApp.Models.Product>
@{
    <h2>Product List</h2>
    <a asp-action="Create">Add New Product</a>

    <table border="1" style="width:100%; border-collapse:collapse;">
        <thead>
            <tr>
                <th>ProductId</th>
                <th>ProductName</th>
                <th>ProductPrice</th>
                <th>Category</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>@item.Price</td>
                    <td>@item.Category</td>
                    <td>
                        <a   asp-controller="Product"     asp-action="Details" asp-route-id="@item.ProductId">View</a>|
                    </td>
                    <td>
                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.ProductId">Edit</a> |
                    </td>
                    <td>
                        <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.ProductId">Delete</a>
                    
                    </td>
                    
                </tr>
            }
        </tbody>
    </table>
}